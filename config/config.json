{
    "model_family": "sdxl",
    "model_type": "lora",
    "pretrained_model_name_or_path": "tools/ComfyUI/models/checkpoints/realcartoonPony_v3.safetensors",
    "data_backend_config": "config/multidatabackend.json",
    "output_dir": "output/flo-lora",

    "lora_rank": 16,
    "lora_alpha": 8,
    "lora_type": "standard",

    "learning_rate": 1e-4,
    "lr_scheduler": "cosine",
    "max_train_steps": 0,
    "num_train_epochs": 10,
    "train_batch_size": 1,
    "seed": 42,

    "optimizer": "torch-adamw",
    "mixed_precision": "fp16",
    "gradient_checkpointing": true,
    "base_model_precision": "int8-quanto",

    "resolution": 1024,
    "resolution_type": "pixel_area",
    "minimum_image_size": 256,
    "aspect_bucket_rounding": 2,

    "caption_dropout_probability": 0.1,
    "checkpoint_step_interval": 100,
    "checkpoints_total_limit": 3,

    "validation_steps": 0,

    "push_to_hub": false,
    "resume_from_checkpoint": "latest",
    "disable_benchmark": false,
    "use_ema": false
}
